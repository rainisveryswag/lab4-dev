<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/void_black">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/void_surface">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAINVOID"
            android:textColor="@color/neon_cyan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by rainisveryswag"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- Neon accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/neon_cyan" />

    <!-- Tab navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/void_surface">

        <Button
            android:id="@+id/btnFragment1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="// PULSE"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="@color/neon_cyan"
            android:textColor="@color/void_black"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <Button
            android:id="@+id/btnFragment2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="// STATIC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="@color/void_surface"
            android:textColor="@color/neon_cyan"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

    <!-- Bottom accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/neon_cyan_dim" />

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/void_black" />

</LinearLayout>
